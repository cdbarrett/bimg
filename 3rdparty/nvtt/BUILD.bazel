load("@rules_cc//cc:defs.bzl", "cc_library")

cc_library(
    name = "nvtt",
    srcs = ["nvtt.cpp"],
    hdrs = ["nvtt.h"],
    copts = [
        "-march=native",
        "-D__STDC_VERSION__=0",
    ],
    cxxopts = ["-std=c++20"],
    include_prefix = "nvtt",
    strip_include_prefix = ".",
    visibility = ["//:__subpackages__"],
    deps = [
        "//3rdparty/nvtt/bc6h",
        "//3rdparty/nvtt/bc7",
        "@bx",
    ],
)
