load("@rules_cc//cc:defs.bzl", "cc_library")

cc_library(
    name = "bc7",
    srcs = glob(["*.cpp"]),
    hdrs = glob(["*.h"]),
    copts = [
        "-march=native",
        "-D__STDC_VERSION__=0",
    ],
    cxxopts = ["-std=c++20"],
    include_prefix = "bc7",
    strip_include_prefix = ".",
    visibility = ["//:__subpackages__"],
    deps = [
        "//3rdparty/nvtt/nvcore",
        "//3rdparty/nvtt/nvmath",
    ],
)
