load("@rules_cc//cc:defs.bzl", "cc_library")

cc_library(
    name = "astc-encoder",
    srcs = glob([
        "source/*.cpp",
        "source/*.h",
    ]),
    hdrs = ["include/astcenc.h"],
    copts = [
        "-msse4.2",
        "-mavx2",
        "-pthread",
    ],
    cxxopts = ["-std=c++20"],
    linkopts = ["-pthread"],
    strip_include_prefix = "include",
    visibility = ["//:__subpackages__"],
)
